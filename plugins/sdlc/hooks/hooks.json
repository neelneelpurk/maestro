{
  "description": "ai-sdlc: drain loop (Stop) + PR quality-gate and AI-disclaimer guards (PreToolUse on Bash).",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/drain-stop-hook.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pr-quality-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ai-disclaimer-guard.sh\""
          }
        ]
      }
    ]
  }
}
